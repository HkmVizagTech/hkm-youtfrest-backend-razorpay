# ── Server ─────────────────────────────────────────────────────────
PORT=3300
NODE_ENV=production

# ── CORS (comma-separated allowed frontend origins) ───────────────
ALLOWED_ORIGINS=https://youthfest.harekrishnavizag.org

# ── Database ───────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<url-encoded-password>@<cluster>/<db>?retryWrites=true&w=majority

# ── Auth ───────────────────────────────────────────────────────────
JWT_SECRET=<generate a long random string>

# ── Razorpay ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Flaxxa WAPI ───────────────────────────────────────────────────
# Brand API token — wapi.flaxxa.com › Brand › API Access
WAPI_TOKEN=
# Language code your templates were approved with (usually "en" or "en_US")
WAPI_TEMPLATE_LANG=en
# Approved template names for each of the 4 message types:
WAPI_TMPL_REGISTRATION=   # Template #1 — registration confirmation
WAPI_TMPL_ATTENDANCE=     # Template #2 — attendance confirmed
WAPI_TMPL_CERTIFICATE=    # Template #3 — certificate delivery (PDF)
WAPI_TMPL_REMINDER=       # Template #4 — event-day reminder broadcast

# ── Cloudinary (certificate PDF hosting) ─────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Google Drive (certificate archival, optional) ─────────────────
GOOGLE_DRIVE_FOLDER_ID=

# ── Legacy Gupshup (kept for reference until fully replaced) ──────
# GUPSHUP_API_KEY=
# GUPSHUP_SOURCE=
# GUPSHUP_TEMPLATE_ID=
